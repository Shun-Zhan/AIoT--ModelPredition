# Copying this file to .env is optional. The one-click startup scripts also
# create .env interactively when the cloud key is missing or invalid. .env is
# ignored by Git and is read automatically; OS environment variables override it.
AIOT_LLM_ENABLED=0
VEI_API_KEY=
VEI_BASE_URL=https://ai-gateway.vei.volces.com/v1
VEI_MODEL=doubao-1.5-thinking-pro
VEI_TIMEOUT_SECONDS=45

# Periodic cloud analysis is non-real-time and defaults to once per 15 min.
AIOT_LLM_INTERVAL_MINUTES=15

# Historical compatibility setting. It no longer triggers a valve command.
AIOT_DEMO_AUTO_EXECUTE=0

# Explicit automatic irrigation. It remains OFF unless the operator opts in.
# START_WATERING still requires fresh/complete telemetry, an IRRIGATION_CANDIDATE
# edge assessment, the confidence threshold, forecast readiness, cooldown and
# daily-limit checks. STOP_WATERING remains available as the conservative action.
AIOT_AUTO_IRRIGATION_ENABLED=0
AIOT_AUTO_IRRIGATION_MIN_CONFIDENCE=0.80
AIOT_AUTO_IRRIGATION_REQUIRE_FORECAST_READY=1

# Local computer edge gateway: sensor risk events and safe adaptive sampling.
# These remain local policies and never allow the cloud model to bypass safety
# checks or directly control GPIO.
AIOT_EVENT_COOLDOWN_SECONDS=300
AIOT_DATA_STALE_SECONDS=20
AIOT_ACTUATOR_ACK_TIMEOUT_SECONDS=15
AIOT_HIGH_ET_TEMP_C=30
AIOT_HIGH_ET_SOLAR_WM2=500
AIOT_HIGH_ET_WIND_MS=2
AIOT_HIGH_ET_SOIL_PERCENT=45
AIOT_NIGHT_SOLAR_WM2=20
AIOT_NIGHT_WIND_MS=1

# Optional nominal valve flow in L/min. Leave empty unless it is measured or
# documented for this valve. It produces an estimate from open duration, not
# a water-meter measurement. An empty value intentionally keeps liters unknown.
AIOT_VALVE_FLOW_LPM=

# Optional farm profile for richer cloud analysis. Fill only facts you know;
# missing values remain explicitly unknown to the model. These fields do not
# change the local valve safety rules.
AIOT_FARM_CROP=
AIOT_FARM_GROWTH_STAGE=
AIOT_FARM_SOIL_TYPE=
AIOT_FARM_PLOT_AREA_M2=
AIOT_FARM_IRRIGATION_METHOD=
AIOT_FARM_NOTES=
