#pragma once

// Copy this file to wifi_credentials.h and fill in the computer hotspot
// credentials. The real file is intentionally ignored by Git.
static const char *ROUTER_SSID = "ESP32_IOT";
static const char *ROUTER_PASSWORD = "CHANGE_THIS_PASSWORD";

// Run `ipconfig` on Windows and find the IPv4 address of "Local Area
// Connection*" belonging to Mobile Hotspot.  This computer currently uses
// 10.98.128.1, so the ESP32 is assigned 10.98.128.50.
// Set false to let the ESP32 obtain an address through DHCP instead.
static const bool USE_WINDOWS_HOTSPOT_STATIC_IP = true;
static IPAddress WINDOWS_HOTSPOT_IP(10, 98, 128, 50);
static IPAddress WINDOWS_HOTSPOT_GATEWAY(10, 98, 128, 1);
static IPAddress WINDOWS_HOTSPOT_SUBNET(255, 255, 255, 0);
static IPAddress WINDOWS_HOTSPOT_DNS(10, 98, 128, 1);
